class Solution {
public:
    vector<bool> prefixesDivBy5(vector<int>& nums) {

       vector<bool> answer;

        int prefix = 0;

        for (int i = 0; i < nums.size(); i++) {

            prefix = (prefix * 2 + nums[i]) % 5;

            answer.push_back((prefix == 0)); 
        }
        
        return answer;
    }
};
